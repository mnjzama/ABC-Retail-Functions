@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="container mt-5 mb-5">
    <div class="card shadow-lg border-0 rounded-4">
        <div class="card-body p-5">
            <h1 class="text-center text-primary fw-bold mb-4">
                🔐 @ViewData["Title"]
            </h1>
            <p class="lead text-center text-muted mb-4">
                At <strong>ABC Retail</strong>, protecting your privacy is our top priority.
                We’re committed to safeguarding your data through transparency, security, and trust.
            </p>

            <hr class="my-4" />

            <h3 class="text-secondary mb-3">1️⃣ Information We Collect</h3>
            <ul class="list-group list-group-flush mb-4">
                <li class="list-group-item"><strong>Customer Info:</strong> Name, email, and contact details.</li>
                <li class="list-group-item"><strong>Product Info:</strong> Descriptions, prices, and inventory details.</li>
                <li class="list-group-item"><strong>Order Data:</strong> Items purchased, status, and history.</li>
                <li class="list-group-item"><strong>Files:</strong> Uploaded documents securely stored in Azure.</li>
            </ul>

            <h3 class="text-secondary mb-3">2️⃣ How We Use Your Data</h3>
            <ul class="mb-4">
                <li>Efficiently process and fulfill orders.</li>
                <li>Store and retrieve media securely using <strong>Azure Blob & File Storage</strong>.</li>
                <li>Enable reliable notifications and updates via <strong>Azure Queues</strong>.</li>
                <li>Deliver personalized shopping experiences based on your preferences.</li>
            </ul>

            <h3 class="text-secondary mb-3">3️⃣ Data Security</h3>
            <p>
                We use <strong>Microsoft Azure Cloud</strong> for end-to-end encryption, ensuring that
                your personal data remains private, protected, and compliant with <strong>POPIA</strong> and <strong>GDPR</strong>.
            </p>

            <h3 class="text-secondary mb-3">4️⃣ Third-Party Access</h3>
            <p>
                We do not sell or share your data. Limited access is granted only for operational
                integrations and legal compliance.
            </p>

            <h3 class="text-secondary mb-3">5️⃣ Your Rights</h3>
            <ul>
                <li>Access, correct, or delete your data anytime.</li>
                <li>Request details about how your information is used.</li>
                <li>Withdraw consent for marketing communications.</li>
            </ul>

            <h3 class="text-secondary mb-3">📩 Contact Us</h3>
            <p>
                Have questions about your privacy? Reach out at:<br />
                <a href="mailto:mnj.zama@gmail.com" class="text-decoration-none text-primary fw-bold">
                    mnj.zama@gmail.com
                </a>
            </p>

            <div class="text-center mt-4">
                <p class="text-muted fst-italic">Your trust fuels our growth — thank you for shopping with ABC Retail 💙</p>
            </div>
        </div>
    </div>
</div>

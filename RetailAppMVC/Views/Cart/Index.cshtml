@model IEnumerable<RetailAppCore.Models.CartItem>
@{
    ViewData["Title"] = "Your Cart";
    var total = (double)(ViewBag.Total ?? 0.0);
}

<div class="container mt-4">
    <h2 class="fw-bold text-primary mb-4">🛒 Your Shopping Cart</h2>

    @if (!Model.Any())
    {
        <div class="alert alert-info shadow-sm">
            😔 Your cart is currently empty. Add some products to get started!
        </div>
        <a class="btn btn-primary mt-2" asp-controller="Product" asp-action="Index">
            🛍 Continue Shopping
        </a>
    }
    else
    {
        <div class="table-responsive shadow-sm rounded mb-4">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Product</th>
                        <th class="text-end">Unit Price</th>
                        <th style="width:130px;">Qty</th>
                        <th class="text-end">Line Total</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@item.ProductName</td>
                            <td class="text-end text-success">💰 R @item.UnitPrice.ToString("N2")</td>
                            <td>
                                <form asp-action="Update" method="post" class="d-flex gap-1">
                                    <input type="hidden" name="productId" value="@item.ProductId" />
                                    <input type="number" name="qty" value="@item.Quantity" min="0" class="form-control form-control-sm" />
                                    <button class="btn btn-sm btn-primary">Update</button>
                                </form>
                            </td>
                            <td class="text-end fw-bold">R @item.LineTotal.ToString("N2")</td>
                            <td class="text-center">
                                <form asp-action="Remove" method="post">
                                    <input type="hidden" name="productId" value="@item.ProductId" />
                                    <button class="btn btn-sm btn-outline-danger">
                                        🗑 Remove
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
                <tfoot class="table-light">
                    <tr>
                        <th colspan="3" class="text-end">Total:</th>
                        <th class="text-end fw-bold text-danger">R @total.ToString("N2")</th>
                        <th></th>
                    </tr>
                </tfoot>
            </table>
        </div>

        <div class="d-flex justify-content-between align-items-center mb-4 gap-2 flex-wrap">
            <a class="btn btn-outline-secondary btn-lg shadow-sm" asp-controller="Product" asp-action="Index">
                🔙 Continue Shopping
            </a>

            <div class="d-flex gap-2 flex-wrap">
                <form asp-action="Clear" method="post">
                    <button class="btn btn-outline-danger btn-lg shadow-sm fw-bold">
                        🗑 Clear Cart
                    </button>
                </form>

                <form asp-action="Checkout" method="get">
                    <button class="btn btn-success btn-lg fw-bold shadow-sm">
                        ✅ Checkout
                    </button>
                </form>
            </div>
        </div>
    }
</div>

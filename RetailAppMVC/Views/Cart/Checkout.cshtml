@model RetailAppCore.ViewModels.CheckoutViewModel

<div class="container mt-4">
    <h2 class="fw-bold text-primary mb-4">🛒 Checkout</h2>

    @if (!Model.CartItems.Any())
    {
        <div class="alert alert-info shadow-sm">
            😔 Your cart is empty. Add some products before checking out!
        </div>
        <a class="btn btn-primary mt-2" asp-controller="Cart" asp-action="Index">🛍 Go to Cart</a>
    }
    else
    {
        <form asp-action="Checkout" method="post">
            <div class="card shadow-sm mb-4">
                <div class="card-body">

                <input type="hidden" asp-for="CustomerId" />

                <div class="mb-3">
                    <label class="form-label fw-bold">👤 Customer</label>
                    <select asp-for="CustomerId" class="form-select" disabled>
                        <option value="@Model.CustomerId">@Model.CustomerName</option>
                    </select>
                </div>

                    <h5 class="fw-bold text-secondary mb-3">📝 Order Summary</h5>

                    <table class="table table-striped table-hover align-middle">
                        <thead class="table-dark">
                            <tr>
                                <th>Product</th>
                                <th class="text-end">Unit Price</th>
                                <th class="text-end">Quantity</th>
                                <th class="text-end">Line Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.CartItems)
                            {
                                <tr>
                                    <td>@item.ProductName</td>
                                    <td class="text-end text-success">R @item.UnitPrice.ToString("N2")</td>
                                    <td class="text-end">@item.Quantity</td>
                                    <td class="text-end fw-bold">R @item.LineTotal.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-light">
                            <tr>
                                <th colspan="3" class="text-end">Total:</th>
                                <th class="text-end text-danger fw-bold">R @Model.Total.ToString("N2")</th>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-success btn-lg shadow-sm">
                    ✅ Confirm Checkout
                </button>
                <a class="btn btn-secondary btn-lg shadow-sm" asp-controller="Cart" asp-action="Index">
                    🔙 Cancel
                </a>
            </div>
        </form>
    }
</div>

@model List<RetailAppCore.Models.Customer>
@{
    ViewData["Title"] = "Search & Filter Customers";
    var query = ViewData["Query"]?.ToString() ?? "";
    var filterBy = ViewData["FilterBy"]?.ToString() ?? "Name";
}

<div class="container my-5">
    <div class="card shadow-lg border-info">
        <div class="card-header bg-info text-white text-center">
            <h3>🔍 Search & Filter Customers</h3>
            <p class="mb-0 small opacity-75">Find customers by name, email, or phone easily 💡</p>
        </div>

        <div class="card-body">
            <form method="get" asp-action="Search" class="row g-3 mb-4">
                <div class="col-md-4">
                    <input type="text" name="query" value="@query" class="form-control" placeholder="Type to search..." />
                </div>

                <div class="col-md-4">
                    <select name="filterBy" class="form-select">
                        <option value="Name" selected="@((filterBy == "Name") ? "selected" : null)">Name</option>
                        <option value="Email" selected="@((filterBy == "Email") ? "selected" : null)">Email</option>
                        <option value="Phone" selected="@((filterBy == "Phone") ? "selected" : null)">Phone</option>
                    </select>
                </div>

                <div class="col-md-4 d-flex gap-2">
                    <button type="submit" class="btn btn-primary flex-grow-1">🔎 Search</button>
                    <a asp-action="Search" class="btn btn-outline-secondary">♻ Reset</a>
                    <a asp-action="Index" class="btn btn-outline-secondary">⬅ Back to List</a>
                </div>
            </form>

            @if (Model == null || !Model.Any())
            {
                <div class="alert alert-info text-center">
                    🙁 No customers found matching your criteria.
                </div>
            }
            else
            {
                <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                    @foreach (var customer in Model)
                    {
                        <div class="col">
                            <div class="card h-100 border-primary shadow-sm">
                                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                                    <strong>@customer.FirstName @customer.LastName</strong>
                                    <small>@customer.Email</small>
                                </div>
                                <div class="card-body">
                                    <p><strong>📞 Phone:</strong> @customer.PhoneNumber</p>
                                </div>
                                <div class="card-footer d-flex justify-content-between">
                                    <a class="btn btn-sm btn-secondary" asp-action="Details" asp-route-partitionKey="@customer.PartitionKey" asp-route-rowKey="@customer.RowKey">ℹ Details</a>
                                    <a class="btn btn-sm btn-warning" asp-action="Edit" asp-route-partitionKey="@customer.PartitionKey" asp-route-rowKey="@customer.RowKey">✏ Edit</a>
                                    <a class="btn btn-sm btn-danger" asp-action="Delete" asp-route-partitionKey="@customer.PartitionKey" asp-route-rowKey="@customer.RowKey">🗑 Delete</a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

@model RetailAppCore.Models.Customer

<div class="container my-5">
    <div class="card shadow-lg border-warning">
        <div class="card-header bg-warning text-dark text-center">
            <h3>✏️ Edit Customer</h3>
            <p class="mb-0 small opacity-75">Keep your customer data fresh and accurate 🧩</p>
        </div>

        <div class="card-body">
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="PartitionKey" />
                <input type="hidden" asp-for="RowKey" />

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="FirstName" class="form-label fw-bold">First Name</label>
                        <input asp-for="FirstName" class="form-control" />
                        <span asp-validation-for="FirstName" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="LastName" class="form-label fw-bold">Last Name</label>
                        <input asp-for="LastName" class="form-control" />
                        <span asp-validation-for="LastName" class="text-danger"></span>
                    </div>
                </div>

                <div class="mt-3">
                    <label asp-for="Email" class="form-label fw-bold">Email</label>
                    <input asp-for="Email" type="email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="mt-3">
                    <label asp-for="PhoneNumber" class="form-label fw-bold">Phone Number</label>
                    <input asp-for="PhoneNumber" class="form-control" />
                    <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                </div>

                <!-- Password Fields (Optional for Edit) -->
                <div class="mt-3">
                    <label asp-for="Password" class="form-label fw-bold">Password (Leave blank to keep current password)</label>
                    <input asp-for="Password" type="password" class="form-control" placeholder="Enter a new password if you want to change it" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <div class="mt-3">
                    <label asp-for="ConfirmPassword" class="form-label fw-bold">Confirm Password</label>
                    <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Confirm your new password" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>

                <div class="d-flex justify-content-end gap-2 mt-4">
                    <a asp-action="Details" asp-route-partitionKey="@Model.PartitionKey" asp-route-rowKey="@Model.RowKey" class="btn btn-outline-secondary">⬅ Back</a>
                    <button type="submit" class="btn btn-success">💾 Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

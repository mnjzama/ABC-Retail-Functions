@model RetailAppCore.Models.Customer

<div class="container my-5">
    <div class="card shadow-lg border-danger">
        <div class="card-header bg-danger text-white text-center">
            <h3>⚠️ Confirm Customer Deletion</h3>
            <p class="mb-0 small opacity-75">This action cannot be undone. Please proceed carefully!</p>
        </div>

        <div class="card-body">
            <ul class="list-group list-group-flush mb-3">
                <li class="list-group-item"><strong>👤 Name:</strong> @Model.FirstName @Model.LastName</li>
                <li class="list-group-item"><strong>📧 Email:</strong> @Model.Email</li>
                <li class="list-group-item"><strong>📞 Phone:</strong> @Model.PhoneNumber</li>
            </ul>

            <form asp-action="Delete" method="post" class="d-flex justify-content-end gap-2">
                <input type="hidden" asp-for="PartitionKey" />
                <input type="hidden" asp-for="RowKey" />
                <a asp-action="Index" class="btn btn-outline-secondary">⬅ Cancel</a>
                <button type="submit" class="btn btn-danger">🗑 Delete Customer</button>
            </form>
        </div>
    </div>
</div>

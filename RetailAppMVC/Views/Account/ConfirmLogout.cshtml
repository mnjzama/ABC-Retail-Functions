@{
    ViewData["Title"] = "Confirm Logout";
}

<div class="container mt-5">
    <div class="text-center">
        <h2 class="fw-bold text-primary">
            ⚠️ Are you sure you want to log out? 🚪
        </h2>
        <p class="text-muted">
            We hope you had a great experience shopping with us! 😊
            <br />
            If you are sure you want to log out, click below.
        </p>

        <div class="d-flex justify-content-center gap-4">
            <form asp-action="Logout" asp-controller="Account" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-danger btn-lg">
                    <i class="bi bi-box-arrow-right"></i> Yes, Log Me Out 🚶‍
                </button>
            </form>

            <a href="@Url.Action("Index", "Product")" class="btn btn-secondary btn-lg">
                <i class="bi bi-x-circle"></i> Cancel, Stay Logged In 🙅‍
            </a>
        </div>

        <div class="mt-4">
            <p class="text-muted">
                Before you go, make sure you're aware of our <strong>Privacy Policy</strong>! 📄
            </p>
            <a href="@Url.Action("Privacy", "Home")" class="btn btn-info btn-lg">
                <i class="bi bi-shield-lock"></i> View Privacy Policy 🔒
            </a>
        </div>

        <div class="mt-4">
            <p class="text-muted">
                Need help? Have questions? You can always reach us at
                <a href="mailto:st10450036@vcconnect.edu.za" class="text-info">
                    st10450036@vcconnect.edu.za 📧
                </a>
            </p>
        </div>
    </div>
</div>

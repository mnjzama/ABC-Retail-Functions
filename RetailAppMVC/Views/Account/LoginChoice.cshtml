@{
    ViewData["Title"] = "Login Selection";
}

<div class="container text-center mt-5">
    <h2 class="fw-bold text-primary mb-4">🔐 Choose Login Type</h2>
    <p class="text-muted mb-5">Select whether you are logging in as a Customer or Admin.</p>

    <div class="d-flex justify-content-center gap-4 mb-4">
        <a class="btn btn-outline-success btn-lg px-5 py-3 shadow-sm"
           asp-action="Login"
           asp-controller="Account">
            👤 Customer Login
        </a>

        <a class="btn btn-outline-danger btn-lg px-5 py-3 shadow-sm"
           asp-action="AdminLogin"
           asp-controller="Account">
            👨‍💼 Admin Login
        </a>
    </div>

    <div class="mt-4">
        <a class="btn btn-outline-primary btn-lg px-4 shadow-sm"
           asp-controller="Home"
           asp-action="Index">
            🏠 Return to Home
        </a>
    </div>

    <p class="text-muted mt-5 fst-italic">
        Need help? Contact <a href="mailto:mnj.zama@gmail.com">mnj.zama@gmail.com</a>
    </p>
</div>

@model string

@{
    ViewData["Title"] = "Delete File";
}

<div class="text-center mb-4">
    <h2 class="fw-bold text-danger">🗑 Delete File</h2>
    <p class="text-muted">⚠️ Are you sure you want to permanently delete this file?</p>
</div>

<div class="card border-danger shadow-sm mb-4">
    <div class="card-body">
        <h5 class="text-danger fw-semibold">📄 File Name: @Model</h5>
        <p class="text-muted mb-0">This action cannot be undone.</p>
    </div>
</div>

<form asp-action="Delete" method="post" class="d-flex gap-2 justify-content-center">
    <input type="hidden" name="fileName" value="@Model" />
    <button type="submit" class="btn btn-danger">
        🗑 Confirm Delete
    </button>
    <a asp-action="Index" class="btn btn-secondary">
        ⬅ Cancel
    </a>
</form>

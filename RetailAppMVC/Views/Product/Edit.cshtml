@model RetailAppCore.Models.Product

<div class="container mt-4">
    <div class="card shadow-lg border-0 p-4">
        <h4 class="mb-3 text-primary"><i class="bi bi-pencil-square me-2"></i> Edit Product</h4>

        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            <input type="hidden" asp-for="PartitionKey" />
            <input type="hidden" asp-for="RowKey" />

            <div class="mb-3">
                <label asp-for="ProductName" class="form-label fw-bold">Product Name</label>
                <input asp-for="ProductName" class="form-control" />
                <span asp-validation-for="ProductName" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label fw-bold">Description</label>
                <textarea asp-for="Description" class="form-control"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Price" class="form-label fw-bold">Price (R)</label>
                <input asp-for="Price" type="number" step="0.01" class="form-control" />
                <span asp-validation-for="Price" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">📷 Product Image</label>
                <input type="file" name="imageFile" class="form-control" />
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <div class="mt-2">
                        <p><strong>Current Image:</strong></p>
                        <img src="@Model.ImageUrl" alt="Product Image" class="img-thumbnail shadow-sm" style="max-width:120px;" />
                    </div>
                }
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-success">💾 Save Changes</button>
                <a asp-action="Index" class="btn btn-outline-secondary">⬅ Back to List</a>
            </div>
        </form>
    </div>
</div>

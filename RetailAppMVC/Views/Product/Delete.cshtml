@model RetailAppCore.Models.Product

<div class="container mt-4">
    <div class="alert alert-danger shadow-sm">
        ⚠️ <strong>Warning:</strong> You are about to permanently delete this product. This action cannot be undone.
    </div>

    <div class="card shadow-sm border-danger">
        <div class="card-header bg-danger text-white">
            <h5 class="mb-0">🗑 Delete Product: @Model.ProductName</h5>
        </div>
        <div class="card-body">
            <p><strong>Price:</strong> R @Model.Price.ToString("N2")</p>

            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <p><img src="@Model.ImageUrl" alt="Product Image" class="img-thumbnail shadow-sm" style="max-width:120px;" /></p>
            }
        </div>
    </div>

    <form asp-action="Delete" method="post" class="mt-3">
        <input type="hidden" asp-for="PartitionKey" />
        <input type="hidden" asp-for="RowKey" />

        <button type="submit" class="btn btn-danger">🗑 Confirm Delete</button>
        <a asp-action="Index" class="btn btn-outline-secondary">⬅ Cancel</a>
    </form>
</div>

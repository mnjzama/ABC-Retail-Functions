@model List<RetailAppCore.Models.Product>
@{
    ViewData["Title"] = "Search & Filter Products";
    var query = ViewData["Query"]?.ToString() ?? "";
    var filterBy = ViewData["FilterBy"]?.ToString() ?? "Name";
}

<div class="container my-5">
    <div class="card shadow-lg border-primary">
        <div class="card-header bg-primary text-white text-center">
            <h3>🔍 Search & Filter Products</h3>
            <p class="mb-0 small opacity-75">Find products by name, description, or price easily 💡</p>
        </div>
        <div class="card-body">
            <form method="get" asp-action="Search" class="row g-3 mb-4">
                <div class="col-md-4">
                    <input type="text" name="query" value="@query" class="form-control" placeholder="Type to search..." />
                </div>              
                <div class="col-md-4">
                    <select name="filterBy" class="form-select">
                        <option value="Name" selected="@((filterBy == "Name") ? "selected" : null)">Name</option>
                        <option value="Description" selected="@((filterBy == "Description") ? "selected" : null)">Description</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <input type="number" name="minPrice" value="@ViewData["MinPrice"]" step="0.01" class="form-control" placeholder="Min Price" />
                </div>
                <div class="col-md-2">
                    <input type="number" name="maxPrice" value="@ViewData["MaxPrice"]" step="0.01" class="form-control" placeholder="Max Price" />
                </div>
                <div class="col-md-4 d-flex gap-2">
                    <button type="submit" class="btn btn-primary flex-grow-1">🔎 Search</button>
                    <a asp-action="Search" class="btn btn-outline-secondary">♻ Reset</a>
                    <a asp-action="Index" class="btn btn-outline-secondary">⬅ Back to List</a>
                </div>
            </form>

            @if (!Model.Any())
            {
                <div class="alert alert-info text-center">🙁 No products found matching your criteria.</div>
            }
            else
            {
                <div class="row row-cols-1 row-cols-md-3 g-4">
                    @foreach (var product in Model)
                    {
                        <div class="col">
                            <div class="card h-100 border-primary shadow-sm">
                                @if (!string.IsNullOrEmpty(product.ImageUrl))
                                {
                                    <img src="@product.ImageUrl" class="card-img-top" alt="@product.ProductName" style="height:200px; object-fit:cover;">
                                }
                                <div class="card-body">
                                    <h5 class="card-title">@product.ProductName</h5>
                                    <p class="card-text">@product.Description</p>
                                    <p class="fw-bold text-success">💰 R @product.Price.ToString("N2")</p>
                                </div>
                                <div class="card-footer d-flex justify-content-between">
                                    <a class="btn btn-sm btn-info" asp-action="Details" asp-route-partitionKey="@product.PartitionKey" asp-route-rowKey="@product.RowKey">ℹ Details</a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

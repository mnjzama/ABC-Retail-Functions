@model List<RetailAppCore.ViewModels.OrderViewModel>

@{
    ViewData["Title"] = "Search & Filter Orders";
    var query = ViewData["Query"]?.ToString() ?? "";
    var filterBy = ViewData["FilterBy"]?.ToString() ?? "Customer";
}

<div class="container my-5">
    <div class="card shadow-lg border-warning">
        <div class="card-header bg-warning text-dark text-center">
            <h3>🔍 Search & Filter Orders</h3>
            <p class="mb-0 small opacity-75">Find orders by customer, product, or status quickly 💡</p>
        </div>

        <div class="card-body">
            <!-- Search Form -->
            <form method="get" asp-action="Search" class="row g-3 mb-4">
                <div class="col-md-4">
                    <input type="text" name="query" value="@query" class="form-control" placeholder="Type to search..." />
                </div>
                <div class="col-md-4">
                    <select name="filterBy" class="form-select">
                        <option value="Customer" selected="@((filterBy == "Customer") ? "selected" : null)">Customer</option>
                        <option value="Product" selected="@((filterBy == "Product") ? "selected" : null)">Product</option>
                        <option value="Status" selected="@((filterBy == "Status") ? "selected" : null)">Status</option>
                    </select>
                </div>
                <div class="col-md-4 d-flex gap-2">
                    <button type="submit" class="btn btn-warning flex-grow-1">🔎 Search</button>
                    <a asp-action="Search" class="btn btn-outline-secondary">♻ Reset</a>
                    <a asp-action="Index" class="btn btn-outline-secondary">⬅ Back to List</a>
                </div>
            </form>

            @if (Model == null || !Model.Any())
            {
                <div class="alert alert-info text-center">
                    🙁 No orders found matching your criteria.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-bordered align-middle">
                        <thead class="table-dark text-center">
                            <tr>
                                <th>👤 Customer</th>
                                <th>🛍 Product</th>
                                <th>🔢 Quantity</th>
                                <th>📅 Order Date</th>
                                <th>💰 Total Price</th>
                                <th>📌 Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in Model)
                            {
                                <tr>
                                    <td>@order.CustomerName</td>
                                    <td>@order.ProductName</td>
                                    <td class="text-center">@order.Quantity</td>
                                    <td>@order.OrderDate.ToString("yyyy-MM-dd")</td>
                                    <td>R @order.TotalPrice.ToString("N2")</td>
                                    <td>@order.Status</td>
                                    <td>
                                        <a class="btn btn-sm btn-info" asp-action="Details" asp-route-partitionKey="@order.PartitionKey" asp-route-rowKey="@order.RowKey">ℹ Details</a>
                                        <a class="btn btn-sm btn-warning" asp-action="Delete" asp-route-partitionKey="@order.PartitionKey" asp-route-rowKey="@order.RowKey">🗑 Delete</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
